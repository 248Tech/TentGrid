{
  "name": "eventgrid",
  "private": true,
  "version": "0.0.2",
  "description": "EventGrid is a browser-based event layout, venue planning, spatial mapping, and quoting platform for event sales and operations teams.",
  "homepage": "https://github.com/248Tech/TentGrid#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/248Tech/TentGrid.git"
  },
  "bugs": {
    "url": "https://github.com/248Tech/TentGrid/issues"
  },
  "keywords": [
    "event-layout",
    "event-planning",
    "tent-planning",
    "venue-planning",
    "sales-ops",
    "nextjs",
    "nestjs",
    "prisma",
    "mapbox",
    "ai"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @eventgrid/api prisma generate",
    "db:deploy": "pnpm --filter @eventgrid/api prisma migrate deploy",
    "db:migrate": "pnpm --filter @eventgrid/api prisma migrate dev",
    "db:seed": "pnpm --filter @eventgrid/api prisma db seed",
    "db:studio": "pnpm --filter @eventgrid/api prisma studio",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-local.ps1",
    "deploy:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-local.ps1",
    "deploy:containers": "docker compose up -d --build"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
